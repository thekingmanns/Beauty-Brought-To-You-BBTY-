{
  "entities": {
    "WaitlistSubmission": {
      "title": "WaitlistSubmission",
      "description": "Information provided by candidates or clients joining the priority waitlist.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the registrant."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address of the registrant."
        },
        "phone": {
          "type": "string",
          "description": "Contact phone number."
        },
        "category": {
          "type": "string",
          "enum": ["client_family", "facility_partner", "salon_owner_stylist", "independent_professional", "aspiring_technician"],
          "description": "Categorization of the interest profile."
        },
        "services": {
          "type": "array",
          "description": "List of services the registrant is interested in."
        },
        "notes": {
          "type": "string",
          "description": "Additional notes and accessibility accommodations."
        },
        "submittedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the submission was created."
        }
      },
      "required": ["name", "email", "phone", "category", "services", "submittedAt"]
    },
    "WaitlistStats": {
      "title": "WaitlistStats",
      "description": "Global stats holding cumulative landing page registration metrics.",
      "type": "object",
      "properties": {
        "count": {
          "type": "integer",
          "description": "Total number of verified waitlist signups."
        }
      },
      "required": ["count"]
    }
  },
  "firestore": {
    "/waitlist/{signUpId}": {
      "schema": {
        "$ref": "#/entities/WaitlistSubmission"
      },
      "description": "Collection of all beauty and care waitlist registrations."
    },
    "/stats/waitlist_stats": {
      "schema": {
        "$ref": "#/entities/WaitlistStats"
      },
      "description": "Global document tracking total registrations."
    }
  }
}
